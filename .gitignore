# Build subdirectories.
/*build*
!/build_msvc

*.pyc

# Only ignore unexpected patches
*.patch
!contrib/guix/patches/*.patch
!depends/patches/**/*.patch

/CMakeUserPresets.json

# Autotools build artifacts
**/.deps/
**/.libs/
/autom4te.cache/
/src/obj/

# Merge script log
/merge.log

# Test cache
/test/cache/

# Previous releases
/releases

#build tests
test/lint/test_runner/target/

/guix-build-*

/ci/scratch/
